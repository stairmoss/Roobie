# ──────────────────────────────────────────────────────
# Roobie — Environment Configuration
# Copy this file to .env and set your values
# ──────────────────────────────────────────────────────

# ── Workspace ─────────────────────────────────────────
# Directory where Roobie generates and manages projects
ROOBIE_WORKSPACE=~/.roobie/workspace

# ── AI Backend ────────────────────────────────────────
# Primary model: HuggingFace model ID for AirLLM disk-offloaded inference
# Recommended lightweight models (runs on 4GB RAM):
#   deepseek-ai/deepseek-coder-1.3b-instruct
#   Qwen/Qwen2.5-Coder-3B-Instruct
#   deepseek-ai/DeepSeek-R1-Distill-Qwen-1.5B
ROOBIE_MODEL=deepseek-ai/deepseek-coder-1.3b-instruct

# AirLLM quantization level (4bit recommended for 4GB RAM)
ROOBIE_AIRLLM_COMPRESSION=4bit

# ── Ollama (optional fallback) ─────────────────────────
ROOBIE_OLLAMA_HOST=http://localhost:11434
ROOBIE_OLLAMA_MODEL=qwen2.5-coder:3b

# ── Web Server ────────────────────────────────────────
ROOBIE_PORT=8484
ROOBIE_HOST=0.0.0.0

# ── Features ──────────────────────────────────────────
# Enable browser automation (requires playwright install)
ROOBIE_BROWSER_ENABLED=true

# Enable vision analysis (requires moondream via Ollama)
ROOBIE_VISION_ENABLED=true

# Enable autonomous improvement loop
ROOBIE_AUTO_IMPROVE=true

# Max tool call loops per turn
ROOBIE_MAX_TOOL_LOOPS=10
