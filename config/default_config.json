{
  "models": {
    "coding_model": "qwen2.5-coder:3b",
    "coding_model_fallback": "deepseek-coder:1.3b",
    "reasoning_model": "deepseek-r1:1.5b",
    "vision_model": "moondream:latest",
    "embedding_model": "nomic-embed-text:latest",
    "ollama_host": "http://localhost:11434",
    "context_length": 4096,
    "temperature": 0.7,
    "max_tokens": 2048,
    "stream": true,
    "num_gpu_layers": 0,
    "num_threads": 4
  },
  "browser": {
    "browser": "chromium",
    "headless": true,
    "viewport_width": 1920,
    "viewport_height": 1080,
    "timeout": 30000
  },
  "research": {
    "searxng_url": "http://localhost:8080",
    "crawl4ai_enabled": true,
    "max_search_results": 10,
    "research_timeout": 60
  },
  "seo": {
    "target_performance": 95,
    "target_accessibility": 95,
    "target_seo": 95,
    "target_best_practices": 95,
    "generate_sitemap": true,
    "generate_robots": true,
    "generate_schema": true
  },
  "memory": {
    "sqlite_db": "~/.roobie/memory.db",
    "chroma_persist_dir": "~/.roobie/chroma"
  },
  "sandbox": {
    "projects_dir": "~/.roobie/projects",
    "default_port": 3000,
    "auto_open_browser": true
  },
  "max_improvement_loops": 5,
  "auto_research": true,
  "auto_improve": true,
  "log_level": "INFO"
}
